# ==========================================================================
# job-research — environment configuration template
# Copy to .env and fill in values. .env is gitignored.
# Nested settings use double-underscore delimiter: LLM__MODEL, SCRAPING__MAX_RETRIES
# ==========================================================================

# ---- General ----
DEBUG=false
LOG_LEVEL=INFO

# ---- LLM API keys (SecretStr — at least one required) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- LLM provider selection ----
# provider: anthropic | openai | openai-compatible
LLM__PROVIDER=anthropic
LLM__MODEL=claude-haiku-4-5-20251001
LLM__MAX_TOKENS=2048
LLM__TEMPERATURE=0.0
LLM__TIMEOUT_SECONDS=60
# Only required for openai-compatible (Ollama / LM Studio / Open WebUI):
LLM__BASE_URL=

# ---- Scraping ----
SCRAPING__MAX_RESULTS_PER_SITE=25
SCRAPING__HOURS_OLD=72
SCRAPING__REQUEST_DELAY_SECONDS=1.5
SCRAPING__MAX_RETRIES=3
SCRAPING__TIMEOUT_SECONDS=30
SCRAPING__LINKEDIN_FETCH_DESCRIPTION=true
# Optional proxies (comma-separated list, e.g. http://user:pass@host:port,...)
SCRAPING__PROXIES=

# ---- Database ----
DATABASE__PATH=data/jobs.duckdb
DATABASE__READ_ONLY=false

# ---- Dashboard ----
DASHBOARD__HOST=localhost
DASHBOARD__PORT=8501
